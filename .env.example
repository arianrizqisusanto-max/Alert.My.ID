# Alert.my.id Environment Variables

# Mock Mode (Set to true to run the application with fully simulated authentication, database, payments, and alerts)
NEXT_PUBLIC_MOCK_MODE=true

# Public App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configurations (Retrieve from Supabase Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configurations (Retrieve from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_BASIC_PRICE_ID=price_basic_id
NEXT_PUBLIC_STRIPE_WHATSAPP_PRICE_ID=price_whatsapp_pro_id

# Resend Email Configuration (Retrieve from Resend Dashboard)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@alert.my.id

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_NAME=AlertMyIdBot

# WhatsApp Cloud API Configuration
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_ENABLED=false

# Cron Security Token (For verifying request is authorized to process reminders)
CRON_SECRET=super-secret-cron-token-change-me
