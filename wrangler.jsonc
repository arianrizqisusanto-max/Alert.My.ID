{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "alert-my-id",
  "main": "src/worker-deploy.ts",
  "compatibility_date": "2025-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "alert-db",
      "database_id": "a1b2c3d4-e5f6-7a8b-9c0d-e1f2a3b4c5d6",
      "migrations_dir": "migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "REMINDER_SCHEDULER",
        "class_name": "ReminderScheduler"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["ReminderScheduler"]
    }
  ]
}
